{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "webview/**", "package.json", "tsconfig.json", "tsconfig.*.json"]
    },
    "build:extension": {
      "dependsOn": ["^build"],
      "outputs": ["dist/extension.js"],
      "inputs": ["src/**", "package.json", "tsconfig.json"]
    },
    "build:webview": {
      "dependsOn": ["^build"],
      "outputs": ["dist/webview/**"],
      "inputs": ["webview/**", "package.json", "tsconfig.webview.json"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "webview/**", "*.config.*"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "webview/**", "tsconfig.json", "tsconfig.*.json"]
    },
    "clean": {
      "cache": false
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["*.vsix"],
      "inputs": ["dist/**", "package.json", ".vscodeignore"]
    }
  }
}
