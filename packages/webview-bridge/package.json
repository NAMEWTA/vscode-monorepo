{
  "name": "@vscode-monorepo/webview-bridge",
  "version": "0.0.1",
  "private": true,
  "description": "Typed bidirectional message bridge between VS Code extension host and React webviews",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "import": "./dist/host.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@vscode-monorepo/shared-types": "*",
    "@vscode-monorepo/shared-utils": "*"
  },
  "devDependencies": {
    "@vscode-monorepo/tsconfig": "*",
    "typescript": "^5.7.0"
  }
}
